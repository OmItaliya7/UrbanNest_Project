{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,

    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,

    "noEmit": true
  },

  "include": ["src"]
}